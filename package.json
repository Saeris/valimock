{
  "name": "valimock",
  "description": "Generate mock data for Valibot schemas using Faker",
  "version": "1.4.0",
  "license": "MIT",
  "author": "Drake Costa <drake@saeris.gg> (https://saeris.gg)",
  "keywords": [
    "valibot",
    "mocking",
    "faker"
  ],
  "homepage": "https://github.com/Saeris/valimock#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/Saeris/valimock.git"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "engines": {
    "node": ">=22.x"
  },
  "packageManager": "yarn@4.14.1",
  "type": "module",
  "main": "./dist/Valimock.js",
  "module": "./dist/Valimock.js",
  "types": "./dist/Valimock.d.ts",
  "exports": {
    ".": {
      "module": "./dist/Valimock.js",
      "import": {
        "types": "./dist/Valimock.d.ts",
        "default": "./dist/Valimock.js"
      },
      "default": "./dist/Valimock.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/**/*"
  ],
  "sideEffects": false,
  "scripts": {
    "ci": "vp check && vp test",
    "build": "vp pack",
    "check": "vp check",
    "format": "vp check --fix",
    "test": "vp test --fileParallelism",
    "typecheck": "vp typecheck"
  },
  "dependencies": {
    "randexp": "^0.5.3"
  },
  "peerDependencies": {
    "@faker-js/faker": ">= 8.0.0",
    "valibot": ">= 0.30.0"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.4.0",
    "@types/node": "25.8.0",
    "@varlock/bumpy": "^1.7.0",
    "@vitest/coverage-v8": "^4.1.6",
    "typescript": "6.0.3",
    "valibot": "^1.4.0",
    "vite-plus": "latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
  },
  "resolutions": {
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
  }
}
